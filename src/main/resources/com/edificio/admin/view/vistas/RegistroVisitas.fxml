<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edificio.admin.view.controladores.VisitaController"
      styleClass="vista-container">

    <Label text="Registro de Visitas" styleClass="titulo-vista"/>

    <!-- ============================================================
         TabPane principal: Tab 1 = Nueva Visita | Tab 2 = Frecuentes
         ============================================================ -->
    <TabPane fx:id="tabPaneVisitas" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- ========================================================
             TAB 1 — Nueva Visita (contenido original intacto)
             ======================================================== -->
        <Tab text="Nueva Visita">
            <content>
                <VBox styleClass="vista-container">

                    <HBox spacing="10" styleClass="barra-herramientas">
                        <Button text="Registrar Visita" onAction="#registrarVisita"   styleClass="boton-accion"/>
                        <Button text="Cancelar Visita"  onAction="#cancelarVisita"    styleClass="boton-accion"/>
                        <Button text="Limpiar"          onAction="#limpiarFormulario" styleClass="boton-accion"/>
                    </HBox>

                    <HBox spacing="20" VBox.vgrow="ALWAYS">

                        <!-- Panel izquierdo: formulario -->
                        <VBox spacing="10" styleClass="panel-formulario" prefWidth="290">
                            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                            <Label text="-- Datos del Visitante --" styleClass="subtitulo"/>

                            <Label text="Nombres:" styleClass="label-formulario"/>
                            <TextField fx:id="txtNombresVisitante" styleClass="campo-texto"/>

                            <Label text="Apellidos:" styleClass="label-formulario"/>
                            <TextField fx:id="txtApellidosVisitante" styleClass="campo-texto"/>

                            <Label text="Tipo Documento:" styleClass="label-formulario"/>
                            <ComboBox fx:id="cmbTipoDocVisitante" maxWidth="Infinity" styleClass="combobox"/>

                            <Label text="Número Documento:" styleClass="label-formulario"/>
                            <TextField fx:id="txtDocVisitante" styleClass="campo-texto"/>

                            <Label text="Foto/Documento ID:" styleClass="label-formulario"/>
                            <HBox spacing="5">
                                <Button text="Seleccionar PDF"
                                        onAction="#seleccionarDocPdf"
                                        styleClass="boton-pequeno"/>
                                <Label fx:id="lblDocPdfSeleccionado"
                                       text="Sin archivo"
                                       styleClass="label-ayuda"
                                       HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <Label text="Teléfono:" styleClass="label-formulario"/>
                            <TextField fx:id="txtTelefonoVisitante" styleClass="campo-texto"/>

                            <Label text="Correo electrónico:" styleClass="label-formulario"/>
                            <TextField fx:id="txtEmailVisitante" promptText="ejemplo@correo.com" styleClass="campo-texto"/>

                            <Separator/>
                            <Label text="-- Datos de la Visita --" styleClass="subtitulo"/>

                            <Label text="Residente Autorizante:" styleClass="label-formulario"/>
                            <ComboBox fx:id="cmbResidente" maxWidth="Infinity" styleClass="combobox"/>

                            <Label text="Tiempo Validez QR (min):" styleClass="label-formulario"/>
                            <Spinner fx:id="spnTiempoValidez" styleClass="spinner" maxWidth="Infinity"/>

                            <Label text="Cantidad de Personas:" styleClass="label-formulario"/>
                            <Spinner fx:id="spnCantPersonas" styleClass="spinner" maxWidth="Infinity"/>

                            <Label text="Notas:" styleClass="label-formulario"/>
                            <TextArea fx:id="txtNotasVisita" styleClass="textarea" prefRowCount="2"/>

                            <Separator/>
                            <Label text="-- Vehículo (opcional) --" styleClass="subtitulo"/>

                             <Label text="Placa:" styleClass="label-formulario"/>
                             <TextField fx:id="txtPlacaVehiculo" styleClass="campo-texto"
                                        promptText="Ej: ABC123 — vacío si viene a pie"/>

                             <Label text="Tipo Vehículo:" styleClass="label-formulario"/>
                             <ComboBox fx:id="cmbTipoVehiculo" maxWidth="Infinity" styleClass="combobox"/>
                         </VBox>

                        <!-- Panel derecho: tabla visitas activas + parqueaderos visitantes -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="Visitas Pendientes y Activas" styleClass="subtitulo"/>
                            <TableView fx:id="tablaVisitas" VBox.vgrow="ALWAYS" styleClass="tabla">
                                <columns>
                                    <TableColumn fx:id="colIdVisita"      text="ID"         prefWidth="50"/>
                                    <TableColumn fx:id="colResidente"     text="Residente"  prefWidth="80"/>
                                    <TableColumn fx:id="colFechaRegistro" text="Registro"   prefWidth="140"/>
                                    <TableColumn fx:id="colCantPersonas"  text="Personas"   prefWidth="70"/>
                                    <TableColumn fx:id="colEstadoVisita"  text="Estado"     prefWidth="90"/>
                                </columns>
                            </TableView>

                            <Label text="Parqueaderos para Visitantes" styleClass="subtitulo"/>
                            <TableView fx:id="tablaParqueaderosVisitantes" styleClass="tabla"
                                       prefHeight="130">
                                <columns>
                                    <TableColumn fx:id="colPrkVCodigo" text="Código" prefWidth="90"/>
                                    <TableColumn fx:id="colPrkVTipo"   text="Tipo"   prefWidth="90"/>
                                    <TableColumn fx:id="colPrkVEstado" text="Estado" prefWidth="120"/>
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                            </TableView>
                        </VBox>

                    </HBox>
                </VBox>
            </content>
        </Tab>

        <!-- ========================================================
             TAB 2 — Visita Rápida: Frecuentes (solo ADMIN)
             ======================================================== -->
        <Tab fx:id="tabFrecuentes" text="Visita Rápida – Frecuentes">
            <content>
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <padding><Insets top="10" bottom="10" left="10" right="10"/></padding>

                    <!-- Panel izquierdo: selector de residente + tabla + mini-formulario -->
                    <VBox spacing="8" styleClass="panel-formulario" prefWidth="340">
                        <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                        <Label text="Residente:" styleClass="label-formulario"/>
                        <ComboBox fx:id="cmbResidenteFrecuente" maxWidth="Infinity" styleClass="combobox"
                                  promptText="Seleccione un residente…"/>

                        <Label text="Visitantes Frecuentes:" styleClass="subtitulo"/>
                        <TableView fx:id="tablaFrecuentes" VBox.vgrow="ALWAYS" styleClass="tabla" prefHeight="200">
                            <columns>
                                <TableColumn fx:id="colNombreFrec"    text="Visitante"  prefWidth="155"/>
                                <TableColumn fx:id="colDocumentoFrec" text="Documento"  prefWidth="100"/>
                                <TableColumn fx:id="colTotalVisitas"  text="Visitas"     prefWidth="55"/>
                                <TableColumn fx:id="colUltimaVisita"  text="Última"      prefWidth="105"/>
                            </columns>
                            <placeholder>
                                <Label text="Seleccione un residente para ver sus frecuentes"/>
                            </placeholder>
                        </TableView>

                        <Separator/>
                        <Label text="-- Modo de llegada HOY (verificar o actualizar) --" styleClass="subtitulo"/>

                        <!-- Referencia histórica: muestra el modo de la última visita registrada -->
                        <Label fx:id="lblUltimoVehiculoFrec" styleClass="label-formulario"
                               wrapText="true" style="-fx-text-fill: #777777; -fx-font-style: italic;"/>

                        <Label text="Cantidad de Personas:" styleClass="label-formulario"/>
                        <Spinner fx:id="spnCantPersonasFrecuente" styleClass="spinner" maxWidth="Infinity"/>

                        <Label text="Tiempo Validez QR (min):" styleClass="label-formulario"/>
                        <Spinner fx:id="spnTiempoValidezFrecuente" styleClass="spinner" maxWidth="Infinity"/>

                        <Label text="Placa:" styleClass="label-formulario"/>
                        <TextField fx:id="txtPlacaFrecuente" styleClass="campo-texto"
                                   promptText="Ej: ABC123 — vacío si viene a pie"/>

                        <Label text="Tipo Vehículo:" styleClass="label-formulario"/>
                        <HBox spacing="6">
                            <ComboBox fx:id="cmbTipoVehiculoFrecuente" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                      styleClass="combobox" promptText="(Sin vehículo — a pie)"/>
                            <Button text="A pie" onAction="#limpiarVehiculoFrecuente"
                                    styleClass="boton-accion"
                                    tooltip="Limpia placa, tipo y descripción en un clic"/>
                        </HBox>

                        <Label text="Descripción (solo si tipo = OTRO):" styleClass="label-formulario"/>
                        <TextField fx:id="txtDescripcionTipoFrecuente" styleClass="campo-texto"
                                   promptText="Ej: Triciclo, Patineta…"/>

                        <Label text="Notas:" styleClass="label-formulario"/>
                        <TextArea fx:id="txtNotasFrecuente" styleClass="textarea" prefRowCount="2"/>

                        <HBox spacing="6">
                            <Button text="Generar QR Rápido" onAction="#liberarVisitaFrecuente"
                                    styleClass="boton-accion" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button text="Ocultar de Lista"  onAction="#ocultarFrecuente"
                                    styleClass="boton-accion" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                    <!-- Panel derecho: resultado QR -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <padding><Insets top="15" bottom="15" left="10" right="15"/></padding>

                        <Label text="-- Código QR Generado --" styleClass="subtitulo"/>
                        <Label fx:id="lblCodigoQRFrecuente" styleClass="valor-destacado" wrapText="true"/>

                        <ImageView fx:id="imgQRFrecuente"
                                   fitWidth="200" fitHeight="200"
                                   preserveRatio="true"
                                   smooth="true"/>

                        <Label text="Compartir QR:" styleClass="label-formulario"/>
                        <!-- Reutilizan los mismos handlers: leen ultimoCodigoQR que se
                             actualiza en liberarVisitaFrecuente() igual que en registrarVisita() -->
                        <HBox spacing="6">
                            <Button text="Correo"   onAction="#compartirPorCorreo"   styleClass="boton-accion" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button text="Telegram" onAction="#compartirPorTelegram" styleClass="boton-accion" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button text="SMS"      onAction="#compartirPorSMS"      styleClass="boton-accion" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>
                    </VBox>

                </HBox>
            </content>
        </Tab>

    </TabPane>

</VBox>
