<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edificio.admin.view.controladores.ContratoController"
      styleClass="vista-container">

    <Label text="Gestión de Contratos" styleClass="titulo-vista"/>

    <HBox spacing="10" styleClass="barra-herramientas">
        <Button text="Crear Contrato" onAction="#crearContrato"    styleClass="boton-accion"/>
        <Button text="Activar"        onAction="#activarContrato"  styleClass="boton-accion"/>
        <Button text="Cancelar"       onAction="#cancelarContrato" styleClass="boton-accion"/>
        <Button text="Limpiar"        onAction="#limpiarFormulario" styleClass="boton-accion"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="10" styleClass="panel-formulario" prefWidth="260">
            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

            <Label text="Apartamento:" styleClass="label-formulario"/>
            <ComboBox fx:id="cmbApartamento" maxWidth="Infinity" styleClass="combobox"/>

            <Label text="Residente Arrendatario:" styleClass="label-formulario"/>
            <ComboBox fx:id="cmbResidente" maxWidth="Infinity" styleClass="combobox"/>

            <Label text="Fecha Inicio:" styleClass="label-formulario"/>
            <DatePicker fx:id="dpFechaInicio" maxWidth="Infinity" styleClass="datepicker"/>

            <Label text="Fecha Fin (opcional):" styleClass="label-formulario"/>
            <DatePicker fx:id="dpFechaFin" maxWidth="Infinity" styleClass="datepicker"/>

            <Label text="Canon Mensual ($):" styleClass="label-formulario"/>
            <TextField fx:id="txtValorMensual" styleClass="campo-texto"/>

            <Label text="Notas:" styleClass="label-formulario"/>
            <TextArea fx:id="txtNotas" styleClass="textarea" prefRowCount="3"/>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="tablaContratos" VBox.vgrow="ALWAYS" styleClass="tabla">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"          prefWidth="50"/>
                    <TableColumn fx:id="colApartamento" text="Apart."      prefWidth="70"/>
                    <TableColumn fx:id="colFechaInicio" text="Inicio"      prefWidth="100"/>
                    <TableColumn fx:id="colFechaFin"    text="Fin"         prefWidth="100"/>
                    <TableColumn fx:id="colValor"       text="Canon $"     prefWidth="100"/>
                    <TableColumn fx:id="colEstado"      text="Estado"      prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
