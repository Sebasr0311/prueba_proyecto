<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edificio.admin.view.controladores.ResidenteController"
      styleClass="vista-container">

    <Label text="Gestión de Residentes" styleClass="titulo-vista"/>

    <HBox spacing="10" styleClass="barra-herramientas">
        <Button text="Nuevo"    onAction="#limpiarFormulario" styleClass="boton-accion"/>
        <Button text="Guardar"  onAction="#guardarResidente"  styleClass="boton-accion"/>
        <Button text="Editar"   onAction="#editarResidente"   styleClass="boton-accion"/>
        <Button text="Eliminar" onAction="#eliminarResidente" styleClass="boton-accion"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="10" styleClass="panel-formulario" prefWidth="260">
            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

            <Label text="Nombres:" styleClass="label-formulario"/>
            <TextField fx:id="txtNombres" styleClass="campo-texto"/>

            <Label text="Apellidos:" styleClass="label-formulario"/>
            <TextField fx:id="txtApellidos" styleClass="campo-texto"/>

            <Label text="Tipo Documento:" styleClass="label-formulario"/>
            <ComboBox fx:id="cmbTipoDocumento" maxWidth="Infinity" styleClass="combobox"/>

            <Label text="Número Documento:" styleClass="label-formulario"/>
            <TextField fx:id="txtDocumento" styleClass="campo-texto"/>

            <Label text="Teléfono:" styleClass="label-formulario"/>
            <TextField fx:id="txtTelefono" styleClass="campo-texto"/>

            <Label text="Email:" styleClass="label-formulario"/>
            <TextField fx:id="txtEmail" styleClass="campo-texto"/>

            <Label text="Fecha Nacimiento:" styleClass="label-formulario"/>
            <DatePicker fx:id="dpFechaNacimiento" maxWidth="Infinity" styleClass="datepicker"/>

            <!-- Estado de edad calculado automáticamente desde la fecha de nacimiento -->
            <Label fx:id="lblEstadoEdad" styleClass="label-formulario" wrapText="true"
                   style="-fx-font-style: italic; -fx-text-fill: #555555;"/>

            <!-- Panel tutor — visible solo cuando chkMenorEdad está activo -->
            <VBox fx:id="panelTutor" spacing="6" visible="false" managed="false"
                  styleClass="panel-formulario">
                <padding><Insets top="8" bottom="4" left="0" right="0"/></padding>
                <Label text="── Datos del Tutor / Responsable ──"
                       styleClass="label-formulario" style="-fx-font-weight:bold;"/>

                <Label text="Nombres tutor:" styleClass="label-formulario"/>
                <TextField fx:id="txtTutorNombres" styleClass="campo-texto"/>

                <Label text="Apellidos tutor:" styleClass="label-formulario"/>
                <TextField fx:id="txtTutorApellidos" styleClass="campo-texto"/>

                <Label text="Tipo Documento:" styleClass="label-formulario"/>
                <ComboBox fx:id="cmbTutorTipoDoc" maxWidth="Infinity" styleClass="combobox"/>

                <Label text="Número Documento:" styleClass="label-formulario"/>
                <TextField fx:id="txtTutorDocumento" styleClass="campo-texto"/>

                <Label text="Teléfono:" styleClass="label-formulario"/>
                <TextField fx:id="txtTutorTelefono" styleClass="campo-texto"/>

                <Label text="Email:" styleClass="label-formulario"/>
                <TextField fx:id="txtTutorEmail" styleClass="campo-texto"/>

                <Label text="Parentesco:" styleClass="label-formulario"/>
                <ComboBox fx:id="cmbParentesco" maxWidth="Infinity" styleClass="combobox"/>
            </VBox>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="tablaResidentes" VBox.vgrow="ALWAYS" styleClass="tabla">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
                    <TableColumn fx:id="colNombres"   text="Nombres"   prefWidth="130"/>
                    <TableColumn fx:id="colApellidos" text="Apellidos" prefWidth="130"/>
                    <TableColumn fx:id="colDocumento" text="Documento" prefWidth="110"/>
                    <TableColumn fx:id="colTelefono"  text="Teléfono"  prefWidth="100"/>
                    <TableColumn fx:id="colEmail"     text="Email"     prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
