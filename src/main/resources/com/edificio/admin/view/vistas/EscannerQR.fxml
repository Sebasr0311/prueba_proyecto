<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Pantalla de escáner / validación de QR y registro de salida.
    Tab 1 — Validar Entrada : portero pega el código QR; SP_VALIDAR_QR es invocado.
    Tab 2 — Registrar Salida: lista de visitantes aún dentro del edificio;
            portero selecciona una fila y pulsa "Registrar Salida".
-->
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edificio.admin.view.controladores.EscannerQRController"
      styleClass="vista-container">

    <Label text="Escáner QR de Acceso" styleClass="titulo-vista"/>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- ══════════════════════════════════════════════════════════════
             TAB 1 – VALIDAR ENTRADA
             ══════════════════════════════════════════════════════════════ -->
        <Tab text="Validar Entrada">
            <content>
                <VBox spacing="10" styleClass="vista-container">

                    <!-- Barra de botones -->
                    <HBox spacing="10" styleClass="barra-herramientas">
                        <Button text="Validar QR"          onAction="#validarQR"          styleClass="boton-accion"/>
                        <Button text="Refrescar Historial" onAction="#refrescarHistorial"  styleClass="boton-accion"/>
                        <Button text="Limpiar"             onAction="#limpiar"             styleClass="boton-accion"/>
                        <Separator/>
                        <Label text="Filtrar por fecha:" styleClass="label-formulario"/>
                        <DatePicker fx:id="dpFiltroFechaQR" prefWidth="130" promptText="DD/MM/AAAA"/>
                    </HBox>

                    <!-- Formulario de entrada + resultado + info visitante -->
                    <HBox spacing="20" alignment="TOP_LEFT">
                        <padding><Insets top="4" bottom="4"/></padding>

                        <!-- Entrada y resultado -->
                        <VBox spacing="8" styleClass="panel-formulario" prefWidth="400">
                            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

                            <Label text="Código QR:" styleClass="label-formulario"/>
                            <TextField fx:id="txtCodigoQR"
                                       promptText="Pegue o escriba el código QR aquí"
                                       styleClass="campo-texto"/>
                            <Label text="(32 caracteres hexadecimales)"
                                   styleClass="label-ayuda"/>

                            <Separator/>

                            <Label text="Resultado:" styleClass="subtitulo"/>
                            <Label fx:id="lblResultado" styleClass="valor-destacado"
                                   wrapText="true" prefHeight="36"/>
                        </VBox>

                        <!-- Info del visitante retornada por SP_VALIDAR_QR -->
                        <VBox spacing="6" styleClass="panel-formulario" HBox.hgrow="ALWAYS">
                            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>
                            <Label text="Información del acceso autorizado:" styleClass="subtitulo"/>
                            <TextArea fx:id="taInfoAcceso"
                                      editable="false"
                                      wrapText="true"
                                      prefRowCount="6"
                                      promptText="La información aparecerá aquí tras validar un QR exitoso."
                                      styleClass="campo-texto"/>
                        </VBox>
                    </HBox>

                    <!-- Historial de QR -->
                    <Label text="Historial de Códigos QR" styleClass="subtitulo"/>

                    <TableView fx:id="tablaQR" VBox.vgrow="ALWAYS" styleClass="tabla">
                        <columns>
                            <TableColumn fx:id="colIdQR"      text="ID QR"     prefWidth="60"/>
                            <TableColumn fx:id="colIdVisita"   text="Visita"    prefWidth="60"/>
                            <TableColumn fx:id="colCodigo"     text="Código"    prefWidth="230"/>
                            <TableColumn fx:id="colExpiracion" text="Expira"    prefWidth="145"/>
                            <TableColumn fx:id="colUsado"      text="Usado"     prefWidth="60"/>
                            <TableColumn fx:id="colFechaUso"   text="Fecha Uso" prefWidth="145"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                </VBox>
            </content>
        </Tab>

        <!-- ══════════════════════════════════════════════════════════════
             TAB 2 – REGISTRAR SALIDA
             ══════════════════════════════════════════════════════════════ -->
        <Tab text="Registrar Salida" fx:id="tabSalida">
            <content>
                <VBox spacing="10" styleClass="vista-container">

                    <Label text="Visitantes actualmente dentro del edificio"
                           styleClass="subtitulo"/>

                    <TableView fx:id="tablaAccesos" VBox.vgrow="ALWAYS" styleClass="tabla">
                        <columns>
                            <TableColumn fx:id="colAccesoId"          text="ID Acceso"    prefWidth="80"/>
                            <TableColumn fx:id="colAccesoVisita"      text="Visita"       prefWidth="70"/>
                            <TableColumn fx:id="colAccesoResidente"   text="Residente"    prefWidth="200"/>
                            <TableColumn fx:id="colAccesoHoraEntrada" text="Hora Entrada" prefWidth="155"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                    <!-- Observaciones + acciones -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <padding><Insets top="4" bottom="4"/></padding>
                        <Label text="Observaciones (opcional):" styleClass="label-formulario"/>
                        <TextField fx:id="txtObservacionesSalida"
                                   promptText="Ej: Salió con equipaje — sin incidencias"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="campo-texto"/>
                        <Button text="Registrar Salida"
                                onAction="#registrarSalida"
                                styleClass="boton-accion"/>
                        <Button text="Refrescar"
                                onAction="#refrescarAccesosActivos"
                                styleClass="boton-accion"/>
                    </HBox>

                </VBox>
            </content>
        </Tab>

<!-- ══════════════════════════════════════════════════════════════
              TAB 3 – PARQUEADEROS (solo lectura — estado actual)
              ══════════════════════════════════════════════════════════════ -->
        <Tab text="Parqueaderos">
            <content>
                <VBox spacing="10" styleClass="vista-container">

                    <HBox spacing="10" styleClass="barra-herramientas">
                        <Label text="Estado:" styleClass="label-formulario"/>
                        <ComboBox fx:id="cmbPrkFiltroEstado" prefWidth="140" promptText="Todos"/>
                        <Label text="Tipo:" styleClass="label-formulario"/>
                        <ComboBox fx:id="cmbPrkFiltroTipo" prefWidth="120" promptText="Todos"/>
                        <Label text="Clasificación:" styleClass="label-formulario"/>
                        <ComboBox fx:id="cmbPrkFiltroClasif" prefWidth="120" promptText="Todos"/>
                        <Button text="Refrescar" onAction="#refrescarParqueaderos" styleClass="boton-accion"/>
                    </HBox>

                    <Label text="Estado Actual de Parqueaderos" styleClass="subtitulo"/>

                    <TableView fx:id="tablaParqueaderosPortero" VBox.vgrow="ALWAYS" styleClass="tabla">
                        <columns>
                            <TableColumn fx:id="colPrkCodigo"       text="Código"       prefWidth="80"/>
                            <TableColumn fx:id="colPrkTipo"         text="Tipo"         prefWidth="90"/>
                            <TableColumn fx:id="colPrkVisitante"    text="Visitante"    prefWidth="70"/>
                            <TableColumn fx:id="colPrkApartamento"  text="Apartamento"  prefWidth="95"/>
                            <TableColumn fx:id="colPrkPropietario"  text="Propietario"  prefWidth="175"/>
                            <TableColumn fx:id="colPrkEstado"       text="Estado"       prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>

                </VBox>
            </content>
        </Tab>

    </TabPane>
</VBox>
