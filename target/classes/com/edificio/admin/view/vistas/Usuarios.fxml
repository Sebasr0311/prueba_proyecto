<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edificio.admin.view.controladores.UsuarioController"
      styleClass="vista-container">

    <Label text="Gestión de Usuarios" styleClass="titulo-vista"/>

    <HBox spacing="10" styleClass="barra-herramientas">
        <Button text="Nuevo"      onAction="#limpiarFormulario"  styleClass="boton-accion"/>
        <Button text="Guardar"    onAction="#guardarUsuario"     styleClass="boton-accion"/>
        <Button text="Desactivar" onAction="#desactivarUsuario"  styleClass="boton-accion"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- ── Panel formulario ── -->
        <VBox spacing="10" styleClass="panel-formulario" prefWidth="280">
            <padding><Insets top="15" bottom="15" left="15" right="15"/></padding>

            <Label text="Username:" styleClass="label-formulario"/>
            <TextField fx:id="txtUsername" styleClass="campo-texto"
                       promptText="Nombre de usuario único"/>

            <Label text="Contraseña:" styleClass="label-formulario"/>
            <PasswordField fx:id="txtPassword" styleClass="campo-texto"
                           promptText="Dejar vacío = no cambiar"/>
            <Label text="(Vacío al editar = mantener la actual)"
                   styleClass="label-ayuda" wrapText="true"/>

            <Label text="Rol:" styleClass="label-formulario"/>
            <ComboBox fx:id="cmbRol" maxWidth="Infinity" styleClass="combobox"/>

            <Label text="ID Residente (opcional):" styleClass="label-formulario"/>
            <TextField fx:id="txtIdResidente" styleClass="campo-texto"
                       promptText="Solo para rol RESIDENTE"/>

            <CheckBox fx:id="chkActivo" text="Usuario activo" styleClass="checkbox"
                      selected="true"/>
        </VBox>

        <!-- ── Tabla ── -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS" styleClass="tabla">
                <columns>
                    <TableColumn fx:id="colUsrId"       text="ID"           prefWidth="50"/>
                    <TableColumn fx:id="colUsrUsername"  text="Username"     prefWidth="150"/>
                    <TableColumn fx:id="colUsrRol"       text="Rol"          prefWidth="100"/>
                    <TableColumn fx:id="colUsrActivo"    text="Activo"       prefWidth="65"/>
                    <TableColumn fx:id="colUsrLogin"     text="Último Login" prefWidth="145"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

    </HBox>
</VBox>
